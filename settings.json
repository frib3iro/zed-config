{
	"cli_default_open_behavior": "existing_window",
	"ui_font_weight": 400.0,
	"hard_tabs": true,
	"agent_servers": {
		"claude-acp": {
			"type": "registry"
		}
	},
	"outline_panel": {
		"dock": "right"
	},
	"collaboration_panel": {
		"dock": "right"
	},
	"git_panel": {
		"tree_view": true,
		"dock": "left"
	},
	"indent_guides": {
		"coloring": "indent_aware",
		"enabled": false
	},
	"show_wrap_guides": true,
	"base_keymap": "SublimeText",
	"autosave": "on_window_change",
	"extend_comment_on_newline": false,
	"ensure_final_newline_on_save": true,
	"remove_trailing_whitespace_on_save": true,
	"buffer_font_family": "Mononoki Nerd Font Mono",
	"ui_font_size": 14.0,
	"buffer_font_size": 15.0,
	"agent_ui_font_size": 16.0,
	"agent_buffer_font_size": 12.0,
	"buffer_line_height": "comfortable",
	"buffer_font_weight": 500.0,
	"theme": "One Dark - Orion",
	"theme_overrides": {
		"One Dark - Orion": {
			"syntax": {
				"comment": { "font_style": "italic" },
				"comment.doc": { "font_style": "italic" },
				"comment.block": { "font_style": "italic" },
				"comment.block.documentation": { "font_style": "italic" }
			}
		}
	},
	"icon_theme": {
		"mode": "dark",
		"light": "Light Charmed Icons",
		"dark": "Soft Charmed Icons"
	},
	"minimap": {
		"show": "always",
		"thumb_border": "left_only"
	},
	"toolbar": {
		"breadcrumbs": false
	},
	"tabs": {
		"file_icons": true
	},
	"soft_wrap": "preferred_line_length",
	"preferred_line_length": 100,
	"vim": {
		"toggle_relative_line_numbers": true
	},
	"edit_predictions": {
		"mode": "subtle"
	},
	"inlay_hints": {
		"enabled": true,
		"show_parameter_hints": false
	},
	"project_panel": {
		"hide_gitignore": true,
		"dock": "left",
		"auto_fold_dirs": false,
		"sticky_scroll": false,
		"scrollbar": {
			"show": "never"
		}
	},
	"file_scan_exclusions": ["**/*.exe", "**/*.obj", "**/*.o"],
	"file_types": {
		"G-code": ["nc", "gcode", "gcd", "tap"]
	},
	"languages": {
		"G-code": {
			"tab_size": 4
		},
		"Markdown": {
			"language_servers": ["markdownlint"],
			"formatter": "language_server"
		},
		"C": {
			"format_on_save": "on",
			"tab_size": 4,
			"formatter": "language_server"
		},
		"C++": {
			"format_on_save": "on",
			"tab_size": 4,
			"formatter": "language_server"
		}
	},
	"lsp": {
		"json-language-server": {
			"settings": {
				"json": {
					"validate": {
						"enable": false
					}
				}
			}
		},
		"markdownlint": {
			"initialization_options": {
				"config": {
					"MD013": {
						"soft_wrap": "preferred_line_length",
						"line_length": 100
					}
				}
			}
		}
	},
	"clangd": {
		"binary": {
			"path": "C:\\Users\\Fabio\\AppData\\Local\\Zed\\languages\\clangd\\clangd_22.1.0\\bin\\clangd.exe",
			"arguments": [
				"--background-index",
				"--clang-tidy",
				"--completion-style=detailed",
				"--header-insertion=iwyu",
				"--pch-storage=memory",
				"--function-arg-placeholders=0",
				"--query-driver=C:/mingw64/bin/g++.exe"
			]
		}
	},
	"language_models": {
		"lmstudio": {
			"api_url": "http://localhost:1234/v1"
		}
	},
	"agent": {
		"default_profile": "write",
		"flexible": true,
		"dock": "right",
		"system_prompt": "Sempre responda em português brasileiro (pt-BR), independente do idioma da pergunta. Sempre formate código usando blocos markdown com a linguagem correta (```cpp, ```c, ```python, etc). Nunca escreva código sem a tag de linguagem.",
		"default_model": {
			"effort": "high",
			"provider": "anthropic",
			"model": "claude-sonnet-4-6",
			"enable_thinking": true
		},
		"favorite_models": [
			{
				"provider": "anthropic",
				"model": "claude-haiku-4-5-20251001",
				"enable_thinking": false
			},
			{
				"provider": "anthropic",
				"model": "claude-sonnet-4-6",
				"enable_thinking": true,
				"effort": "high"
			}
		],
		"tool_permissions": {
			"tools": {
				"terminal": {
					"always_allow": [
						{ "pattern": "^cmake\\b" },
						{ "pattern": "^make\\b" },
						{ "pattern": "^clang\\b" },
						{ "pattern": "^clang\\+\\+\\b" },
						{ "pattern": "^ninja\\b" }
					]
				}
			}
		}
	},
	"telemetry": {
		"diagnostics": false,
		"metrics": false
	},
	"debugger": {
		"log_dap_communications": true,
		"format_dap_log_messages": true
	}
}
